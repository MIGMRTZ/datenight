# DateNight Autopilot — Environment Variables
# Copy to .env and fill in values

# Auth token for Cloudflare Worker communication (required for all API calls)
DATENIGHT_AUTH_TOKEN=your-secret-token-here

# GitHub token for auto-PR creation (optional)
GITHUB_TOKEN=

# Optional overrides (these override config.yaml values)
# DATENIGHT__LOCATION__ZIP=75165
# DATENIGHT__LOCATION__CITY=Waxahachie
# DATENIGHT__CLOUDFLARE__WORKER_URL=https://datenight-api.your-domain.workers.dev
# DATENIGHT__OLLAMA__MODEL=mistral:7b
# DATENIGHT__LOGGING__LEVEL=DEBUG
